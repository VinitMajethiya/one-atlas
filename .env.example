# NextAuth — Required for production auth token encryption
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-production-domain.com

# Cron Security
CRON_SECRET=your-cron-secret-here

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_API_KEY=your-admin-secret-here

# Seeding — Required for hashing seeded admin credentials (change before seeding in production)
SEED_ADMIN_PASSWORD=changeme_on_first_login
